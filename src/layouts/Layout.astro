---
import "../styles/tailwind.css";

interface Props {
  title: string;
  description?: string;
  user?: { id: string; email: string; displayName: string } | null;
}

const { title, description, user } = Astro.props;
const metaDescription = description ?? "QuickCut - Collaborative video review";
---

<!doctype html>
<html lang="en" class="bg-bg-primary text-text-primary">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={metaDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
    <title>{title} | QuickCut</title>
  </head>
  <body class="min-h-screen bg-bg-primary font-sans antialiased">
    {
      user && (
        <header class="sticky top-0 z-50 flex h-14 items-center border-b border-border-default bg-bg-primary px-8">
          <a href="/dashboard" class="text-lg font-bold text-text-primary">
            QuickCut
          </a>
          <div class="ml-auto flex items-center gap-4">
            <span class="text-sm text-text-secondary">
              {user.displayName}
            </span>
            <form method="POST" action="/api/auth/logout">
              <button
                type="submit"
                class="text-sm text-text-tertiary transition-colors duration-150 hover:text-text-primary"
              >
                Logout
              </button>
            </form>
          </div>
        </header>
      )
    }
    <main>
      <slot />
    </main>
  </body>
</html>
