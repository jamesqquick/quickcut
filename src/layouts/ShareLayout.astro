---
import "../styles/tailwind.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-bg-primary text-text-primary">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="QuickCut - Video Review" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
    <title>{title} | QuickCut</title>
  </head>
  <body class="min-h-screen bg-bg-primary font-sans antialiased">
    <header class="flex h-14 items-center border-b border-border-default bg-bg-primary px-8">
      <a href="/" class="text-lg font-bold text-text-primary">QuickCut</a>
    </header>
    <main class="mx-auto max-w-[1200px] px-4 py-8">
      <slot />
    </main>
  </body>
</html>
