---
import { UserMenu } from "./UserMenu";

interface Props {
  user?: { id: string; email: string; name: string } | null;
  backLink?: { href: string; label: string };
}

const { user, backLink } = Astro.props;
---

<header class="sticky top-0 z-50 flex h-14 items-center border-b border-border-default bg-bg-primary px-8">
  <a href="/dashboard" class="text-lg font-bold text-text-primary">
    Quick Cuts
  </a>

  {backLink && (
    <a href={backLink.href} class="ml-6 text-sm text-text-tertiary transition-colors hover:text-text-primary">
      {backLink.label}
    </a>
  )}

  {user && (
    <div class="ml-auto flex items-center">
      <UserMenu client:load name={user.name} email={user.email} />
    </div>
  )}
</header>
