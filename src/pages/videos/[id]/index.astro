---
import Layout from "../../../layouts/Layout.astro";
import { InlineEditor } from "../../../components/InlineEditor";
import { ProjectActivityTimeline } from "../../../components/ProjectActivityTimeline";
import { ProjectPhaseControls } from "../../../components/ProjectPhaseControls";
import { TargetDateEditor } from "../../../components/TargetDateEditor";
import { VideoHeader } from "../../../components/VideoHeader";
import { env } from "cloudflare:workers";
import { eq } from "drizzle-orm";
import { createDb } from "../../../db";
import { scripts, shareLinks, spaces, videos } from "../../../db/schema";
import { getApprovalStatus } from "../../../lib/approvals";
import { getProjectActivity } from "../../../lib/activity";
import { verifySpaceAccess } from "../../../lib/spaces";
import { normalizeVideoPhase, type VideoPhase } from "../../../types";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const { id } = Astro.params;
if (!id) return Astro.redirect("/dashboard");

const db = createDb(env.DB);
const videoResult = await db.select().from(videos).where(eq(videos.id, id)).limit(1);
const video = videoResult[0];
if (!video) return Astro.redirect("/dashboard");

const role = await verifySpaceAccess(db, user.id, video.spaceId);
if (!role) return Astro.redirect("/dashboard");

const shareLinkResult = await db.select().from(shareLinks).where(eq(shareLinks.videoId, id)).limit(1);
const shareLink = shareLinkResult[0] || null;
const appUrl = new URL(Astro.request.url).origin;
const spaceResult = await db
  .select({ id: spaces.id, name: spaces.name, pipelineEnabled: spaces.pipelineEnabled })
  .from(spaces)
  .where(eq(spaces.id, video.spaceId))
  .limit(1);
const videoSpace = spaceResult[0] ?? { id: video.spaceId, name: "Space", pipelineEnabled: false };
const scriptResult = await db.select({ status: scripts.status, plainText: scripts.plainText }).from(scripts).where(eq(scripts.videoId, video.id)).limit(1);
const script = scriptResult[0] || null;
const hasScriptContent = !!script?.plainText?.trim();
const approvalStatus = await getApprovalStatus(db, video.id, video.spaceId);
const projectActivity = await getProjectActivity(db, video.id);
const backHref = `/dashboard?space=${video.spaceId}${video.folderId ? `&folderId=${video.folderId}` : ""}`;
const phase = normalizeVideoPhase(video.phase) as VideoPhase;
const isPublished = phase === "published";
const hasVideo = !!video.streamVideoId;
const isPublishable = approvalStatus.requiredApprovals <= 0 || approvalStatus.isApproved;
const canChangePhase = videoSpace.pipelineEnabled && (role === "owner" || video.uploadedBy === user.id);
const canMarkAsPublished = !isPublished && hasVideo && canChangePhase && isPublishable;
const enabledSteps = isPublished || hasVideo || script?.status === "review"
    ? ["overview", "script", "review"]
    : ["overview", "script"];
const primaryAction = isPublished
  ? { type: "link" as const, label: "View Video", href: `/videos/${video.id}/review?space=${video.spaceId}` }
  : canMarkAsPublished
    ? {
        type: "phase" as const,
        label: "Mark as Published",
        phase: "published" as const,
        confirmMessage: "Marking this project as published locks the script, comments, and versions. This assumes you have published the video manually elsewhere.",
      }
    : !hasScriptContent
      ? { type: "link" as const, label: "Add Script", href: `/videos/${video.id}/script?space=${video.spaceId}` }
      : !hasVideo && script?.status === "review"
        ? { type: "link" as const, label: "Upload Video", href: `/videos/${video.id}/upload?space=${video.spaceId}` }
        : !hasVideo
          ? { type: "link" as const, label: "Continue Script", href: `/videos/${video.id}/script?space=${video.spaceId}` }
          : { type: "link" as const, label: "Review Video", href: `/videos/${video.id}/review?space=${video.spaceId}` };
const scriptDescription = script?.plainText?.trim()
  ? `${script.plainText.trim().slice(0, 140)}${script.plainText.trim().length > 140 ? "..." : ""}`
  : "Open the script workspace to draft, review, or reference the approved script.";
const videoDescription = hasVideo
  ? isPublished
    ? "Watch the final cut and review the locked feedback history."
    : "Review the current cut, comments, approvals, transcript, and versions."
  : "Upload the first cut when the script is ready.";
---

<Layout title={`${video.title} Overview`} user={user} selectedSpaceId={video.spaceId}>
  <div class="mx-auto max-w-[1180px] px-4 py-6 sm:px-8 sm:py-8">
    <VideoHeader
      client:load
      videoId={video.id}
      shareLink={shareLink}
      appUrl={appUrl}
      spaceId={video.spaceId}
      backHref={backHref}
      spaceName={videoSpace.name}
      uploadVersionHref={!isPublished && hasVideo && role === "owner" ? `/videos/${video.id}/upload?space=${video.spaceId}` : null}
    />

    <div class="space-y-8">
      {videoSpace.pipelineEnabled && (
        <div class="mb-10">
          <ProjectPhaseControls
            client:load
            videoId={video.id}
            initialPhase={phase}
            currentStep="overview"
            enabledSteps={enabledSteps}
            lockedStepMessages={!hasVideo && script?.status !== "review" ? { review: "Add and submit the script before moving to video." } : undefined}
            primaryAction={primaryAction}
          />
        </div>
      )}

      <section class="rounded-2xl border border-border-default bg-bg-secondary p-5 sm:p-6">
        <div class="space-y-6">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-tertiary">Metadata</p>
            <InlineEditor
              client:load
              value={video.title}
              field="title"
              videoId={video.id}
              isOwner={role === "owner" && !isPublished}
              as="h1"
              className="min-w-0 break-words text-2xl font-bold text-text-primary sm:text-3xl"
            />
          </div>

          <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-wide text-text-tertiary">Description</p>
            <InlineEditor
              client:load
              value={video.description || ""}
              field="description"
              videoId={video.id}
              isOwner={role === "owner" && !isPublished}
              placeholder="Add a description..."
              className="w-full break-words text-sm text-text-secondary"
            />
          </div>

          <div class="max-w-sm space-y-2">
            <p class="text-xs font-semibold uppercase tracking-wide text-text-tertiary">Target publish date</p>
            <TargetDateEditor client:load videoId={video.id} initialTargetDate={video.targetDate} canEdit={canChangePhase && !isPublished} variant="plain" />
          </div>
        </div>
      </section>

      {isPublished && (
        <section class="rounded-2xl border border-border-default bg-bg-secondary p-5 sm:p-6">
          <div class="rounded-lg border border-accent-secondary/30 bg-accent-secondary/10 px-4 py-2 text-sm text-accent-secondary">
            This project is published. Script, comments, and versions are read-only, but you can still view each artifact.
          </div>
        </section>
      )}

      <div class="grid gap-4 md:grid-cols-2">
        <a href={`/videos/${video.id}/script?space=${video.spaceId}`} class="group rounded-xl border border-border-default bg-bg-secondary p-5 transition-all hover:-translate-y-0.5 hover:border-accent-primary/50 hover:bg-bg-tertiary/60 hover:shadow-lg hover:shadow-black/20">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold text-text-primary">Script</p>
              <p class="mt-2 text-sm text-text-secondary">{scriptDescription}</p>
            </div>
            <span class="shrink-0 whitespace-nowrap rounded-full border border-border-default px-2.5 py-1 text-xs text-text-tertiary">
              {script?.status === "review" ? "In review" : "Writing"}
            </span>
          </div>
          <p class="mt-4 inline-flex rounded-lg bg-accent-primary/10 px-3 py-1.5 text-xs font-semibold text-accent-primary transition-colors group-hover:bg-accent-primary group-hover:text-white">View script</p>
        </a>

        <a href={hasVideo ? `/videos/${video.id}/review?space=${video.spaceId}` : `/videos/${video.id}/upload?space=${video.spaceId}`} class="group rounded-xl border border-border-default bg-bg-secondary p-5 transition-all hover:-translate-y-0.5 hover:border-accent-primary/50 hover:bg-bg-tertiary/60 hover:shadow-lg hover:shadow-black/20">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold text-text-primary">Video</p>
              <p class="mt-2 text-sm text-text-secondary">{videoDescription}</p>
            </div>
            <span class="shrink-0 whitespace-nowrap rounded-full border border-border-default px-2.5 py-1 text-xs text-text-tertiary">
              {hasVideo ? video.status === "ready" ? "Ready" : "Processing" : "Not uploaded"}
            </span>
          </div>
          <p class="mt-4 inline-flex rounded-lg bg-accent-primary/10 px-3 py-1.5 text-xs font-semibold text-accent-primary transition-colors group-hover:bg-accent-primary group-hover:text-white">{hasVideo ? "View video" : "Upload video"}</p>
        </a>
      </div>

      {approvalStatus.requiredApprovals > 0 && (
        <section class="rounded-xl border border-border-default bg-bg-secondary p-5">
          <p class="text-sm font-semibold text-text-primary">Approvals</p>
          <p class="mt-2 text-sm text-text-secondary">
            {approvalStatus.currentApprovals} of {approvalStatus.requiredApprovals} approvals complete.
            {approvalStatus.isApproved ? " This project is cleared to publish." : " Publishing is locked until approvals are complete."}
          </p>
        </section>
      )}

      {videoSpace.pipelineEnabled && <ProjectActivityTimeline client:load activity={projectActivity} />}
    </div>
  </div>
</Layout>
