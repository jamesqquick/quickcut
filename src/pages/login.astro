---
import Layout from "../layouts/Layout.astro";

const user = Astro.locals.user;
if (user) {
  return Astro.redirect("/dashboard");
}

const error = Astro.url.searchParams.get("error");
const message = Astro.url.searchParams.get("message");
---

<Layout title="Sign In">
  <div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center px-4">
    <div class="w-full max-w-[400px]">
      <div class="mb-8 text-center">
        <a href="/" class="inline-block text-3xl font-bold text-text-primary">Quick Cuts</a>
        <p class="mt-2 text-sm text-text-secondary">
          Collaborative video review. Upload, share, get feedback.
        </p>
      </div>

      <div class="rounded-2xl border border-border-default bg-bg-secondary p-8">
        {message && (
          <div class="mb-4 rounded-lg bg-accent-warning/15 px-4 py-2 text-sm text-accent-warning">
            {message}
          </div>
        )}
        {error && (
          <div class="mb-4 rounded-lg bg-accent-danger/15 px-4 py-2 text-sm text-accent-danger">
            {error}
          </div>
        )}

        <form method="POST" action="/api/auth/login" class="space-y-4">
          <div>
            <label for="email" class="mb-1 block text-sm font-medium text-text-secondary">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full rounded-lg border border-border-default bg-bg-input px-4 py-2.5 text-sm text-text-primary placeholder:text-text-tertiary focus:border-accent-primary focus:outline-none"
              placeholder="you@example.com"
            />
          </div>
          <div>
            <label for="password" class="mb-1 block text-sm font-medium text-text-secondary">
              Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              class="w-full rounded-lg border border-border-default bg-bg-input px-4 py-2.5 text-sm text-text-primary placeholder:text-text-tertiary focus:border-accent-primary focus:outline-none"
              placeholder="Enter your password"
            />
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="rememberMe" name="rememberMe" class="accent-accent-primary" />
            <label for="rememberMe" class="text-sm text-text-secondary">Remember me</label>
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-accent-primary px-5 py-2.5 text-sm font-medium text-white transition-all duration-150 hover:bg-accent-hover hover:shadow-[0_2px_8px_rgba(108,92,231,0.3)]"
          >
            Sign In
          </button>
        </form>

        <p class="mt-6 text-center text-sm text-text-tertiary">
          Don't have an account?{" "}
          <a href="/register" class="text-accent-primary hover:text-accent-hover">
            Register
          </a>
        </p>
      </div>
    </div>
  </div>
</Layout>
