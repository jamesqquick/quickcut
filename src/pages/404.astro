---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Not Found">
  <div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center px-4">
    <div class="text-center">
      <p class="text-6xl font-bold text-text-tertiary">404</p>
      <h1 class="mt-4 text-2xl font-bold text-text-primary">Page Not Found</h1>
      <p class="mt-2 text-sm text-text-secondary">
        The page you're looking for doesn't exist.
      </p>
      <a
        href="/"
        class="mt-6 inline-block rounded-lg bg-accent-primary px-5 py-2.5 text-sm font-medium text-white transition-all duration-150 hover:bg-accent-hover hover:shadow-[0_2px_8px_rgba(108,92,231,0.3)]"
      >
        Go Home
      </a>
    </div>
  </div>
</Layout>
